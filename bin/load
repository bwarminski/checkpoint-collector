#!/usr/bin/env ruby
# ABOUTME: Runs the load runner CLI for benchmark workloads.
# ABOUTME: Dispatches the run subcommand through the Load namespace.
VERSION_PATH = File.expand_path("../VERSION", __dir__)
USAGE = "Usage: bin/load run --workload PATH --adapter PATH --app-root PATH [--readiness-path /up|none] [--startup-grace-seconds 15]".freeze

if ARGV.include?("--help") || ARGV.include?("-h")
  puts USAGE
  exit 0
end

if ARGV.include?("--version") || ARGV.include?("-v")
  puts File.read(VERSION_PATH).strip
  exit 0
end

require_relative "../load/lib/load"

command = ARGV.shift
if command == "run"
  exit Load::CLI.new(argv: ARGV, stdout: $stdout, stderr: $stderr).run
end

warn USAGE
exit 2
